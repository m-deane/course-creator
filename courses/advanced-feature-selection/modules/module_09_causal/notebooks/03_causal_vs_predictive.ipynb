   "source": [
    "# Purpose: Show the blending logic and its effect on the feature set\n",
    "# Key concept: blending captures both robustness and accuracy\n",
    "\n",
    "print(\"Feature Set Composition\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "icp_set = set(icp_features)\n",
    "predictive_union = set(lasso_features) | set(shap_features) | set(rf_features)\n",
    "\n",
    "consensus = icp_set & predictive_union\n",
    "icp_only = icp_set - predictive_union\n",
    "predictive_only = predictive_union - icp_set\n",
    "production_set = consensus | icp_only  # Causal features: always include\n",
    "monitoring_set = predictive_only       # Watch for drift\n",
    "\n",
    "print(f\"\\nConsensus (causal ∩ predictive):     {sorted(consensus)}\")\n",
    "print(f\"  → Include always\")\n",
    "print(f\"\\nCausal only (ICP − predictive):      {sorted(icp_only)}\")\n",
    "print(f\"  → Include for robustness\")\n",
    "print(f\"\\nPredictive only (predictive − ICP):  {sorted(predictive_only)}\")\n",
    "print(f\"  → Include with drift monitoring\")\n",
    "print(f\"\\nProduction feature set:  {sorted(production_set)}\")\n",
    "print(f\"Monitoring set:          {sorted(monitoring_set)}\")\n",
    "\n",
    "# Evaluate production set\n",
    "prod_results = evaluate_method_under_shift(\n",
    "    list(production_set), X_train, y_train, shift_strengths, FEATURE_NAMES\n",
    ")\n",
    "print(f\"\\nProduction set performance:\")\n",
    "for shift, r2 in prod_results:\n",
    "    print(f\"  Shift={shift:.1f}: R²={r2:.4f}\")"
